<?xml version="1.0" encoding="UTF-8"?>
<!--
  Mock IdP metadata for development and testing.
  In production, replace this file (or the metadata-uri property) with the
  real identity provider's metadata URL or XML document.

  Key elements:
  - entityID:          The IdP's unique identifier
  - IDPSSODescriptor:  Declares the IdP's SSO binding and certificate
  - SingleSignOnService: The URL Spring Security redirects the browser to
-->
<md:EntityDescriptor
    xmlns:md="urn:oasis:names:tc:SAML:2.0:metadata"
    xmlns:ds="http://www.w3.org/2000/09/xmldsig#"
    entityID="https://mock-idp.example.com/saml/metadata">

  <md:IDPSSODescriptor
      WantAuthnRequestsSigned="false"
      protocolSupportEnumeration="urn:oasis:names:tc:SAML:2.0:protocol">

    <md:KeyDescriptor use="signing">
      <ds:KeyInfo>
        <ds:X509Data>
          <ds:X509Certificate></ds:X509Certificate>
        </ds:X509Data>
      </ds:KeyInfo>
    </md:KeyDescriptor>

    <md:KeyDescriptor use="encryption">
      <ds:KeyInfo>
        <ds:X509Data>
          <ds:X509Certificate></ds:X509Certificate>
        </ds:X509Data>
      </ds:KeyInfo>
    </md:KeyDescriptor>

    <!--
      In a real integration this points to the IdP's SSO endpoint.
      For this demo we use a local placeholder; the .with(saml2Login())
      test post-processor bypasses the actual redirect entirely.
    -->
    <md:SingleSignOnService
        Binding="urn:oasis:names:tc:SAML:2.0:bindings:HTTP-POST"
        Location="http://localhost:8092/mock-idp/saml2/sso"/>

    <md:SingleSignOnService
        Binding="urn:oasis:names:tc:SAML:2.0:bindings:HTTP-Redirect"
        Location="http://localhost:8092/mock-idp/saml2/sso"/>

  </md:IDPSSODescriptor>

</md:EntityDescriptor>
